# Copy this file to .env and fill in your values.

# MongoDB Atlas: Database > Connect > Drivers > Node.js — paste the connection string.
# Replace <password> with your DB user password. Example:
# mongodb+srv://user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/smart_tasks?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/smart_tasks?retryWrites=true&w=majority

# Strong random string for signing JWTs (e.g. openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Optional: defaults to 7d in code
JWT_EXPIRES_IN=7d

PORT=5000
